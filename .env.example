# ── Convex deploy key ────────────────────────────────────────────────────────
# Deploys the Convex backend (functions + schema) to production.
# In this project, Convex is deployed SEPARATELY from Vercel — run it yourself,
# either manually or from your own CI (NOT on Vercel):
#     npx convex deploy
# Create a Production/Preview deploy key at:
#     https://dashboard.convex.dev/project/settings#production-deploy-keys
# Not needed for local development (`npx convex dev`).
CONVEX_DEPLOY_KEY=

# ── Frontend → Convex URL ────────────────────────────────────────────────────
# The deployed Convex URL the Next.js client and auth middleware connect to.
# REQUIRED on Vercel (Project Settings → Environment Variables): Vercel only runs
# `next build` and does NOT inject this automatically. NEXT_PUBLIC_ vars are
# inlined at build time, so it must be set before the Vercel build runs.
# Find it in the Convex dashboard (Settings → URL & Deploy Key), e.g.
#     https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_URL=
