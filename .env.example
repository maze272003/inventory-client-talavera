# This environment variable is used in Production and Preview environments to deploy your Convex project
# This variable is not needed in development.
# You can create a Production or Preview deploy key at https://dashboard.convex.dev/project/settings#production-deploy-keys
#
# On Vercel: add CONVEX_DEPLOY_KEY in Project Settings → Environment Variables.
# The build command in vercel.json (`npx convex deploy --cmd 'npm run build'`)
# deploys the Convex backend and automatically injects NEXT_PUBLIC_CONVEX_URL
# into the Next.js build, so you do NOT need to set NEXT_PUBLIC_CONVEX_URL manually.
CONVEX_DEPLOY_KEY=
