{
  "name": "inventory-talavera",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "next dev",
    "dev:backend": "convex dev",
    "predev": "convex dev --until-success && convex dashboard",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ignore-pattern \"convex/_generated/**\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed:auth": "node scripts/seed-auth-users.mjs",
    "seed:fresh": "npx convex run --push databaseMaintenance:resetWithMasterSeed \"{\\\"confirm\\\":\\\"RESET_DATABASE\\\"}\"",
    "typecheck": "tsc --noEmit",
    "typecheck:convex": "tsc --noEmit -p convex/tsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@auth/core": "^0.41.2",
    "@convex-dev/auth": "^0.0.94",
    "convex": "^1.36.1",
    "geist": "^1.7.2",
    "next": "16.2.4",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^2.0.0",
    "@edge-runtime/vm": "^5.0.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "convex-test": "^0.0.53",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
